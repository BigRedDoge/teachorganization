terraform {
  required_version = ">= 1.10"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 6.0"
    }
    cloudflare = {
      source  = "cloudflare/cloudflare"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "us-east-1"

  default_tags {
    tags = {
      Project   = "teachorganization"
      ManagedBy = "terraform"
    }
  }
}

provider "cloudflare" {
  # reads CLOUDFLARE_API_TOKEN from the environment
}